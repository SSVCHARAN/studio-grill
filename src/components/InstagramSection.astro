---
import { site, instagramHighlights } from '../config/site';
import { imageSlots } from '../config/images';
import { resolveImage } from '../utils/resolveImage';

const gridImages = imageSlots.instagramGrid
  .map((slot) => ({ slot, src: resolveImage(slot) }))
  .filter((item): item is { slot: typeof item.slot; src: string } => Boolean(item.src));
---

<section class="section section--tight" id="instagram">
  <div class="container">
    <p class="eyebrow">As on Instagram</p>
    <h2>See SCG in action</h2>
    <p>
      Follow <a href={site.instagram} target="_blank" rel="noopener">{site.instagramHandle}</a> for
      reels, celebrations, and daily specials.
    </p>
    {
      gridImages.length > 0 && (
        <div class="insta-grid insta-grid--photos" style="margin: 1.5rem 0">
          {gridImages.map(({ slot, src }) => (
            <a class="insta-tile insta-tile--photo" href={site.instagram} target="_blank" rel="noopener">
              <img src={src} alt={slot.alt} loading="lazy" decoding="async" />
            </a>
          ))}
        </div>
      )
    }
    <div class="btn-group">
      {instagramHighlights.map((h) => (
        <a
          class="btn btn--secondary btn--sm"
          href={h.href}
          target={h.href.startsWith('http') ? '_blank' : undefined}
          rel={h.href.startsWith('http') ? 'noopener' : undefined}
        >
          {h.label}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .insta-grid--photos .insta-tile--photo {
    padding: 0;
    overflow: hidden;
    aspect-ratio: 1;
  }

  .insta-grid--photos .insta-tile--photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
