---
import { whatsappUrl, waMessages, contact, appLinks } from '../config/site';

interface Props {
  title?: string;
  subtitle?: string;
  waMessage?: string;
  showFood?: boolean;
}

const {
  title = 'Ready to create your moment?',
  subtitle = 'Book theaters, sports, celebrations, or food — we reply fastest on WhatsApp.',
  waMessage = waMessages.book,
  showFood = false,
} = Astro.props;

const hasApp = Boolean(appLinks.ios || appLinks.android);
---

<section class="section section--tight scroll-reveal">
  <div class="container">
    <div class="cta-band-premium">
      <div class="cta-band-premium__glow" aria-hidden="true"></div>
      <div class="cta-band-premium__content">
        <p class="eyebrow" style="justify-content: center; margin-bottom: 1rem; --gold: #e6c47a;">Let's go</p>
        <h2 style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);">{title}</h2>
        <p style="max-width: 44ch; margin-inline: auto; font-size: 1.05rem;">{subtitle}</p>
        <div class="btn-group" style="justify-content: center; margin-top: 2rem; gap: 1rem;">
          <a class="btn btn--primary btn--glow" href={whatsappUrl(waMessage)} target="_blank" rel="noopener">
            ✨ Book on WhatsApp
          </a>
          <a class="btn btn--secondary" href={`tel:${contact.phone}`}>Call {contact.phoneDisplay}</a>
          {showFood && (
            <a class="btn btn--secondary" href={whatsappUrl(waMessages.food)} target="_blank" rel="noopener">
              Order food
            </a>
          )}
        </div>
        {hasApp && (
          <div class="app-badges" style="justify-content: center; margin-top: 1.25rem">
            {appLinks.android && (
              <a class="app-badge app-badge--live" href={appLinks.android} target="_blank" rel="noopener">
                Download Android App
              </a>
            )}
            {appLinks.ios && (
              <a class="app-badge app-badge--live" href={appLinks.ios} target="_blank" rel="noopener">
                Download iOS App
              </a>
            )}
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .cta-band-premium {
    position: relative;
    border-radius: var(--radius-xl);
    padding: 4rem 3rem;
    text-align: center;
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--border);
  }

  .cta-band-premium__glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 60% at 30% 0%, rgba(212, 168, 83, 0.1) 0%, transparent 60%),
      radial-gradient(ellipse 40% 50% at 70% 100%, rgba(232, 93, 58, 0.06) 0%, transparent 60%),
      radial-gradient(ellipse 30% 30% at 50% 50%, rgba(45, 106, 79, 0.04) 0%, transparent 50%);
    pointer-events: none;
    animation: ctaGlow 6s ease-in-out infinite alternate;
  }

  @keyframes ctaGlow {
    0% { opacity: 0.7; }
    100% { opacity: 1; transform: scale(1.05); }
  }

  .cta-band-premium__content {
    position: relative;
    z-index: 1;
  }

  .cta-band-premium::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 160px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }

  .cta-band-premium::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--ember), transparent);
  }
</style>
