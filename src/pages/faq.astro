---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import { faq } from '../config/site';

const title = 'FAQ';
const description = 'Frequently asked questions about Zexa Events private theaters, sports, dining, packages, and visits in Visakhapatnam.';
---

<BaseLayout title={title} description={description}>
  <div class="page-hero">
    <div class="container reveal">
      <p class="eyebrow">Help</p>
      <h1>Frequently asked questions</h1>
      <p>Answers before you message us on WhatsApp.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      {faq.map((group) => (
        <div style="margin-bottom: 2.5rem">
          <h2 style="color: var(--gold); font-size: 1.35rem">{group.category}</h2>
          {group.items.map((item) => (
            <details class="faq-item">
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          ))}
        </div>
      ))}
    </div>
  </section>

  <CtaBand subtitle="Still unsure? Message us — we typically reply fastest on WhatsApp." />
</BaseLayout>
