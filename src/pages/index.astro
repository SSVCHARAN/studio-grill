---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import InstagramSection from '../components/InstagramSection.astro';
import SiteImage from '../components/SiteImage.astro';
import RoomPicker from '../components/RoomPicker.astro';
import PackageConfigurator from '../components/PackageConfigurator.astro';
import { imageSlots } from '../config/images';
import { resolveImage } from '../utils/resolveImage';
import {
  site,
  address,
  contact,
  experiences,
  whyScg,
  theaters,
  sports,
  menu,
  packages,
  whatsappUrl,
  waMessages,
} from '../config/site';

const heroSrc = resolveImage(imageSlots.hero);

const expImages = {
  theater: imageSlots.theaters.room,
  sports: imageSlots.sports.cricket,
  dining: imageSlots.dining.food,
  packages: imageSlots.packages.celebration,
} as const;

const accentColors = {
  theater: 'var(--cinema-glow)',
  sports: 'var(--turf-glow)',
  dining: 'var(--ember-glow)',
  packages: 'var(--gold-light)',
};
---

<BaseLayout title={site.name} showSchema={true}>

  <!-- ═══════════ HERO — Cinematic Full-Viewport ═══════════ -->
  <section class:list={['hero', heroSrc && 'hero--has-photo']}>
    {heroSrc && <div class="hero__photo" style={`background-image: url(${heroSrc})`} aria-hidden="true" />}
    <div class="hero__bg" aria-hidden="true"></div>
    <div class="hero__grain" aria-hidden="true"></div>
    
    <!-- Floating particles -->
    <div class="hero__particles" aria-hidden="true">
      <span class="particle particle--1"></span>
      <span class="particle particle--2"></span>
      <span class="particle particle--3"></span>
      <span class="particle particle--4"></span>
      <span class="particle particle--5"></span>
    </div>

    <div class="container hero__content">
      <p class="eyebrow hero-anim hero-anim--1">{site.shortName} · {site.city}</p>
      <h1 class="hero-anim hero-anim--2">{site.tagline}</h1>
      <p class="hero__sub hero-anim hero-anim--3">
        Private 4K theaters · Sports arena · Indo-American dining · Celebration packages — one
        destination in Sagar Nagar.
      </p>
      <div class="btn-group hero-anim hero-anim--4">
        <a class="btn btn--primary btn--glow" href={whatsappUrl(waMessages.book)} target="_blank" rel="noopener">
          ✨ Book your experience
        </a>
        <a class="btn btn--secondary" href="#dining">Explore dining</a>
        <a class="btn btn--secondary" href="#packages">View packages</a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-hint hero-anim hero-anim--5" aria-hidden="true">
      <span>Scroll to explore</span>
      <div class="scroll-hint__line"></div>
    </div>
  </section>

  <!-- ═══════════ TRUST STRIP — Floating bar ═══════════ -->
  <section class="trust-bar scroll-reveal">
    <div class="container">
      <div class="trust-bar__inner">
        <div class="trust-bar__item">
          <span class="trust-bar__icon">🕐</span>
          <div>
            <strong>{site.hoursShort}</strong>
            <span>Daily</span>
          </div>
        </div>
        <div class="trust-bar__divider"></div>
        <div class="trust-bar__item">
          <span class="trust-bar__icon">📍</span>
          <div>
            <strong>{address.landmark}</strong>
            <span>{site.city}</span>
          </div>
        </div>
        <div class="trust-bar__divider"></div>
        <div class="trust-bar__item">
          <span class="trust-bar__icon">💰</span>
          <div>
            <strong>{site.costForTwo} for two</strong>
            <span>{site.costForTwoNote}</span>
          </div>
        </div>
        <div class="trust-bar__divider"></div>
        <div class="trust-bar__item">
          <span class="trust-bar__icon">🍃</span>
          <div>
            <strong>Clean Kitchen</strong>
            <span>No food coloring · No MSG</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ EXPERIENCES — Staggered cards ═══════════ -->
  <section class="section">
    <div class="container">
      <div class="section-header scroll-reveal">
        <p class="eyebrow">Experiences</p>
        <h2>Everything in one place</h2>
        <p style="max-width: 50ch;">Four distinct experiences under one roof — choose your vibe and we'll handle the rest.</p>
      </div>
      <div class="exp-grid">
        {experiences.map((exp, i) => {
          const imgSlot = expImages[exp.accent as keyof typeof expImages];
          const imgSrc = resolveImage(imgSlot);
          const color = accentColors[exp.accent as keyof typeof accentColors];
          return (
          <a href={exp.href} class:list={['card', `card--${exp.accent}`, 'experience-card', imgSrc && 'experience-card--has-img', 'scroll-reveal-item']} style={`text-decoration: none; --delay: ${i * 0.12}s;`} data-accent={exp.accent}>
            {imgSrc && (
              <div class="experience-card__img-wrap">
                <SiteImage imageSlot={imgSlot} aspect="card" class="experience-card__img" />
              </div>
            )}
            <div class="experience-card__body">
              <span class="experience-card__accent-line" style={`background: ${color};`}></span>
              <h3>{exp.title}</h3>
              <p style="margin: 0">{exp.description}</p>
              <span class="experience-card__arrow">→</span>
            </div>
          </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ═══════════ WHY ZEXA — Number highlights ═══════════ -->
  <section class="section section--tight" style="background: var(--bg-card)">
    <div class="container">
      <div class="section-header scroll-reveal" style="text-align: center; max-width: 600px; margin-inline: auto;">
        <p class="eyebrow" style="justify-content: center;">Why {site.shortName}</p>
        <h2>Built for memorable outings</h2>
      </div>
      <div class="why-grid">
        {whyScg.map((item, i) => (
          <div class="why-card scroll-reveal-item" style={`--delay: ${i * 0.1}s;`}>
            <span class="why-card__number">{String(i + 1).padStart(2, '0')}</span>
            <h3 style="color: var(--gold); font-size: 1.15rem;">{item.title}</h3>
            <p style="margin: 0">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ THEATERS ═══════════ -->
  <section id="theaters" class="section section--ambient-theater">
    <div class="container">
      <div class="section-header scroll-reveal">
        <p class="eyebrow">Private Theaters & Gaming</p>
        <h2>Immersive Entertainment</h2>
        <p style="max-width: 55ch;">Enjoy 4K laser projection, Dolby Atmos Q-SYS audio, and premium comforts in our dedicated rooms.</p>
      </div>
      
      <div class="grid-asym scroll-reveal" style="margin-top: 2.5rem; align-items: start;">
        <div>
          <div class="rooms-grid">
            {theaters.rooms.map((room, i) => (
              <div class="card card--theater room-card scroll-reveal-item" style={`--delay: ${i * 0.08}s;`}>
                <div class="room-card__capacity">{room.capacity.split('–')[1] || room.capacity} <small>guests</small></div>
                <h3 style="font-size: 1.05rem; margin-bottom: 0.35rem;">{room.name}</h3>
                <p style="margin: 0; font-size: 0.85rem;">{room.bestFor}</p>
              </div>
            ))}
          </div>
          <div class="scroll-reveal" style="margin-top: 2.5rem">
            <h3 style="font-size: 1.15rem; margin-bottom: 1rem;">Tech & Comforts</h3>
            <ul class="feature-list">
              {theaters.tech.map(t => <li>{t}</li>)}
              {theaters.comfort.map(c => <li>{c}</li>)}
              {theaters.content.map(c => <li>{c}</li>)}
            </ul>
          </div>
        </div>
        <div class="configurator-panel sticky-panel glass-panel scroll-reveal">
          <RoomPicker />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ SPORTS ═══════════ -->
  <section id="sports" class="section section--ambient-sports">
    <div class="container">
      <div class="section-header scroll-reveal">
        <p class="eyebrow">Sports Arena</p>
        <h2>Active Entertainment</h2>
        <p style="max-width: 50ch;">Three sports, one venue — perfect for groups, leagues, and weekend fun.</p>
      </div>
      <div class="sports-grid">
        {sports.items.map((sport, i) => (
          <div class="card card--sports sport-card scroll-reveal-item" style={`--delay: ${i * 0.12}s;`}>
            <div class="sport-card__icon">{sport.title === 'Box Cricket' ? '🏏' : sport.title === 'Pickleball' ? '🏓' : '🏐'}</div>
            <h3 style="font-size: 1.2rem;">{sport.title}</h3>
            <p>{sport.description}</p>
            <ul class="feature-list" style="margin-bottom: 1.5rem;">
              {sport.details.map(d => <li>{d}</li>)}
            </ul>
            <a class="btn btn--sm btn--whatsapp" style="margin-top: auto; align-self: flex-start;" href={whatsappUrl(waMessages.sports)} target="_blank" rel="noopener">Book {sport.title}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ INLINE CTA ═══════════ -->
  <section class="section section--tight inline-cta scroll-reveal">
    <div class="container">
      <div class="inline-cta__inner">
        <div>
          <h2 style="font-size: clamp(1.5rem, 3vw, 2.2rem); margin-bottom: 0.5rem;">Ready to play or celebrate?</h2>
          <p style="margin: 0; max-width: 40ch;">We reply fastest on WhatsApp. Tell us what you need and we'll set it up.</p>
        </div>
        <div class="btn-group" style="flex-shrink: 0;">
          <a class="btn btn--primary btn--glow" href={whatsappUrl(waMessages.book)} target="_blank" rel="noopener">Book on WhatsApp</a>
          <a class="btn btn--secondary" href={`tel:${contact.phone}`} >Call us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ DINING ═══════════ -->
  <section id="dining" class="section section--ambient-dining">
    <div class="container">
      <div class="section-header scroll-reveal">
        <p class="eyebrow">Dining & Menu</p>
        <h2>Indo-American Grill</h2>
        <p style="max-width: 50ch;">From smoky kebabs to loaded pizzas — crafted fresh with no food coloring and no MSG.</p>
      </div>
      
      <div class="grid-asym scroll-reveal" style="margin-top: 2.5rem; align-items: start;">
        <div class="sticky-panel">
          <div class="grid-2" style="margin-bottom: 2rem;">
            {
              resolveImage(imageSlots.dining.food) && (
                <div style="border-radius: var(--radius-lg); overflow: hidden;">
                  <SiteImage imageSlot={imageSlots.dining.food} aspect="card" />
                </div>
              )
            }
            {
              resolveImage(imageSlots.dining.garden) && (
                <div style="border-radius: var(--radius-lg); overflow: hidden;">
                  <SiteImage imageSlot={imageSlots.dining.garden} aspect="card" />
                </div>
              )
            }
          </div>
          <a class="btn btn--whatsapp" href={whatsappUrl(waMessages.food)} target="_blank" rel="noopener" style="width: 100%; justify-content: center;">
            Order / call for takeaway & dine-in
          </a>
        </div>
        
        <div class="menu-cards">
          {menu.sections.map((section, i) => (
            <div class="card card--dining menu-card scroll-reveal-item" style={`--delay: ${i * 0.1}s;`}>
              <h3 class="menu-card__title">{section.title}</h3>
              <ul class="menu-list">
                {section.items.map(item => (
                  <li class="menu-item">
                    <strong>{item.name}</strong>
                    <span>{item.note}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ PACKAGES ═══════════ -->
  <section id="packages" class="section section--ambient-packages">
    <div class="container">
      <div class="section-header scroll-reveal">
        <p class="eyebrow">Celebrations</p>
        <h2>Packages & Events</h2>
        <p style="max-width: 50ch;">From intimate movie nights to grand celebrations — pick a tier and customize your experience.</p>
      </div>
      <div class="grid-asym scroll-reveal" style="margin-top: 2.5rem; align-items: start;">
        <div>
          <div class="packages-grid">
            {packages.tiers.map((tier, i) => (
              <div class:list={['card', 'card--packages', 'package-tier', 'scroll-reveal-item', i === 2 && 'package-tier--featured']} style={`--delay: ${i * 0.1}s;`}>
                {i === 2 && <span class="package-tier__badge">Most Popular</span>}
                <h3 style="margin-bottom: 0.25rem;">{tier.name}</h3>
                <p class="package-tier__price">From ₹{tier.from.toLocaleString('en-IN')}</p>
                <ul class="feature-list">
                  {tier.includes.map(inc => <li style="padding-top: 0.25rem; padding-bottom: 0.25rem; font-size: 0.85rem">{inc}</li>)}
                </ul>
              </div>
            ))}
          </div>
          <div class="scroll-reveal" style="margin-top: 2.5rem">
            <h3 style="font-size: 1.15rem; margin-bottom: 1rem;">Premium Add-ons</h3>
            <div class="addons-row">
              {packages.addons.map(addon => (
                <div class="addon-pill">
                  <span class="addon-pill__dot"></span>
                  {addon.name}
                </div>
              ))}
            </div>
          </div>
        </div>
        <div class="configurator-panel sticky-panel glass-panel scroll-reveal">
          <PackageConfigurator />
        </div>
      </div>
    </div>
  </section>

  <InstagramSection />

  <!-- ═══════════ VISIT ═══════════ -->
  <section id="visit" class="section">
    <div class="container grid-2 scroll-reveal" style="align-items: center; gap: 3rem;">
      <div>
        <p class="eyebrow">Visit us</p>
        <h2>{address.landmark}</h2>
        <p style="font-size: 1.05rem; line-height: 1.8;">{address.full}</p>
        <p><strong style="color: var(--cream)">{site.hours}</strong></p>
        <div style="margin-top: 2rem;">
          <a class="btn btn--secondary" href={address.directionsUrl} target="_blank" rel="noopener">Get directions →</a>
        </div>
      </div>
      <div class="map-frame">
        <iframe
          title="Zexa Events location map"
          loading="lazy"
          src={`https://maps.google.com/maps?q=${encodeURIComponent(address.full)}&output=embed`}
        ></iframe>
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>

<script>
  // ═══════════ SCROLL REVEAL ENGINE ═══════════
  // Uses IntersectionObserver — GPU-friendly, no scroll event listeners
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -60px 0px' });

    document.querySelectorAll('.scroll-reveal, .scroll-reveal-item').forEach(el => {
      revealObserver.observe(el);
    });

    // Parallax on hero photo (Desktop only)
    const isMobile = window.innerWidth < 768;
    const heroPhoto = document.querySelector('.hero__photo') as HTMLElement;
    if (heroPhoto && !isMobile) {
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const scrollY = window.scrollY;
            const heroH = window.innerHeight;
            if (scrollY < heroH) {
              heroPhoto.style.transform = `translateY(${scrollY * 0.3}px) scale(${1 + scrollY * 0.0003})`;
            }
            ticking = false;
          });
          ticking = true;
        }
      });
    }

    // Header background on scroll
    const header = document.querySelector('.site-header') as HTMLElement;
    if (header) {
      let headerTicking = false;
      window.addEventListener('scroll', () => {
        if (!headerTicking) {
          requestAnimationFrame(() => {
            if (window.scrollY > 80) {
              header.classList.add('header--scrolled');
            } else {
              header.classList.remove('header--scrolled');
            }
            headerTicking = false;
          });
          headerTicking = true;
        }
      });
    }
  }
</script>

<style>
  /* ── Reduced motion & Mobile Performance ──────────── */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }

  @media (max-width: 768px) {
    .scroll-reveal, .scroll-reveal-item {
      /* Speed up animations on mobile and reduce travel distance */
      transform: translateY(16px) scale(0.98) !important;
      transition-duration: 0.5s !important;
    }
    .scroll-reveal.is-visible, .scroll-reveal-item.is-visible {
      transform: translateY(0) scale(1) !important;
    }
    .hero__photo {
      will-change: auto;
      transform: none !important;
    }
  }

  /* ── Desktop Sticky Panels ──────────── */
  @media (min-width: 900px) {
    .sticky-panel {
      position: sticky;
      top: calc(var(--header-h) + 2rem);
    }
  }

  /* ── Hero entrance animations ── */
  .hero-anim {
    opacity: 0;
    transform: translateY(30px);
    animation: heroEntrance 0.9s var(--ease-out-expo) forwards;
  }
  .hero-anim--1 { animation-delay: 0.2s; }
  .hero-anim--2 { animation-delay: 0.4s; }
  .hero-anim--3 { animation-delay: 0.6s; }
  .hero-anim--4 { animation-delay: 0.85s; }
  .hero-anim--5 { animation-delay: 1.4s; }

  @keyframes heroEntrance {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Floating particles ──────── */
  .hero__particles {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    border-radius: 50%;
    background: var(--gold);
    opacity: 0.15;
    animation: particleFloat linear infinite;
  }
  .particle--1 { width: 4px; height: 4px; left: 15%; top: 30%; animation-duration: 14s; }
  .particle--2 { width: 6px; height: 6px; left: 70%; top: 20%; animation-duration: 18s; animation-delay: -4s; }
  .particle--3 { width: 3px; height: 3px; left: 40%; top: 60%; animation-duration: 12s; animation-delay: -7s; }
  .particle--4 { width: 5px; height: 5px; left: 85%; top: 50%; animation-duration: 16s; animation-delay: -2s; }
  .particle--5 { width: 4px; height: 4px; left: 25%; top: 75%; animation-duration: 20s; animation-delay: -10s; }

  @keyframes particleFloat {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0; }
    10% { opacity: 0.2; }
    50% { transform: translate(40px, -80px) scale(1.5); opacity: 0.15; }
    90% { opacity: 0.2; }
  }

  /* ── Scroll hint ─────────────── */
  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-dim);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .scroll-hint__line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.6); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  /* ── Glowing CTA button ──────── */
  .btn--glow {
    position: relative;
    z-index: 1;
  }
  .btn--glow::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: inherit;
    background: linear-gradient(135deg, var(--gold), var(--ember), var(--gold));
    z-index: -1;
    opacity: 0.6;
    filter: blur(12px);
    animation: glowPulse 3s ease-in-out infinite;
  }

  @keyframes glowPulse {
    0%, 100% { opacity: 0.4; transform: scale(0.95); }
    50% { opacity: 0.7; transform: scale(1.05); }
  }

  /* ── Trust bar ───────────────── */
  .trust-bar {
    position: relative;
    z-index: 10;
    margin-top: -3rem;
    padding: 0;
  }

  .trust-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 1.5rem 2.5rem;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
  }

  .trust-bar__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
  }

  .trust-bar__item strong {
    display: block;
    color: var(--cream);
    font-size: 0.9rem;
  }

  .trust-bar__item span:not(.trust-bar__icon) {
    color: var(--text-dim);
    font-size: 0.75rem;
  }

  .trust-bar__icon {
    font-size: 1.5rem;
  }

  .trust-bar__divider {
    width: 1px;
    height: 32px;
    background: var(--border);
  }

  @media (max-width: 768px) {
    .trust-bar__inner {
      gap: 1rem;
      padding: 1.25rem 1.5rem;
    }
    .trust-bar__divider {
      display: none;
    }
    .trust-bar__item {
      flex: 1 1 40%;
    }
  }

  /* ── Section header ──────────── */
  .section-header {
    margin-bottom: 0.5rem;
  }

  /* ── Scroll reveal ───────────── */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 1s var(--ease-out-expo), transform 1s var(--ease-out-expo);
    will-change: transform, opacity;
  }
  .scroll-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .scroll-reveal-item {
    opacity: 0;
    transform: translateY(32px) scale(0.97);
    transition: opacity 0.8s var(--ease-out-expo), transform 0.8s var(--ease-out-expo);
    transition-delay: var(--delay, 0s);
    will-change: transform, opacity;
  }
  .scroll-reveal-item.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* ── Experience grid ─────────── */
  .exp-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    margin-top: 2.5rem;
  }

  .experience-card__img-wrap {
    overflow: hidden;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }

  .experience-card__body {
    padding: 1.5rem;
    position: relative;
  }

  .experience-card__accent-line {
    position: absolute;
    top: 0;
    left: 1.5rem;
    width: 32px;
    height: 3px;
